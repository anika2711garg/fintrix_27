{
  "info": {
    "name": "Fintrix API",
    "description": "Postman collection for Fintrix backend endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"Admin\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "me"]
        }
      }
    },
    {
      "name": "Users - List (pagination/search)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/users?page=1&limit=10&search=admin",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "users"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "search", "value": "admin" }
          ]
        }
      }
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "users", "{{userId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"Analyst\",\n  \"status\": \"Active\"\n}"
        }
      }
    },
    {
      "name": "Users - Soft Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "users", "{{userId}}"]
        }
      }
    },
    {
      "name": "Records - List (pagination/search)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records?page=1&limit=10&search=food",
          "host": ["{{baseUrl}}"],
          "path": ["api", "records"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "search", "value": "food" }
          ]
        }
      }
    },
    {
      "name": "Records - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records",
          "host": ["{{baseUrl}}"],
          "path": ["api", "records"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 2500,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-01T00:00:00.000Z\",\n  \"description\": \"Monthly salary\"\n}"
        }
      }
    },
    {
      "name": "Records - Soft Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records/{{recordId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "records", "{{recordId}}"]
        }
      }
    },
    {
      "name": "Dashboard - Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/dashboard/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dashboard", "summary"]
        }
      }
    },
    {
      "name": "Dashboard - Insights",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/dashboard/insights",
          "host": ["{{baseUrl}}"],
          "path": ["api", "dashboard", "insights"]
        }
      }
    }
  ]
}
